# Server
PORT=3000
PLATFORM_TOKEN=j0I6MsdaRqUgKmVuqc8nvIdrX7mcMTonDz6a
DEFAULT_WORKSPACE_ID=default

# Security
# Recommended: use a strong random value in production.
MASTER_KEY=replace-with-strong-master-key

# Runtime Policy
REQUEST_TIMEOUT_MS=8000
MAX_REDIRECTS=3
TRACE_RETENTION_DAYS=7

# SSRF / Local Debug
# true only for local tests that call localhost/private IP.
ALLOW_PRIVATE_UPSTREAM=false
ENABLE_SKILL_LIBRARY=true
SKILL_LIBRARY_PATH=skills/skill-library.json

# LLM Providers
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

DEEPSEEK_API_KEY=sk-fe2675ea6e7d47e5a93462e729503e35
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Admin Auth
ENABLE_ADMIN_AUTH=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=D123

# Local Test User Auth
LOCAL_PASSWORD_AUTH_ENABLED=true
LOCAL_TEST_USERNAME=test1
LOCAL_TEST_PASSWORD=test1
