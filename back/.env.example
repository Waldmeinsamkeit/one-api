# Server
PORT=
PLATFORM_TOKEN=
DEFAULT_WORKSPACE_ID=

# Security
# Recommended: use a strong random value in production.
MASTER_KEY=

# Runtime Policy
REQUEST_TIMEOUT_MS=
MAX_REDIRECTS=
TRACE_RETENTION_DAYS=

# SSRF / Local Debug
# true only for local tests that call localhost/private IP.
ALLOW_PRIVATE_UPSTREAM=
ENABLE_SKILL_LIBRARY=
SKILL_LIBRARY_PATH=

# LLM Providers
OPENAI_API_KEY=
OPENAI_BASE_URL=

GEMINI_API_KEY=
GEMINI_BASE_URL=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=

# Admin Auth
ENABLE_ADMIN_AUTH=
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Local Test User Auth
LOCAL_PASSWORD_AUTH_ENABLED=
LOCAL_TEST_USERNAME=
LOCAL_TEST_PASSWORD=
